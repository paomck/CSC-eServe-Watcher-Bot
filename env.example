# ============================================================
# CSC eServe Watcher - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# Your CSC eServe session cookie string.
# How to get it:
#   1. Log in to services.csc.gov.ph in your browser.
#   2. Open DevTools (F12) → Application → Cookies → services.csc.gov.ph
#   3. Copy ALL Name=Value pairs into a single line, separated by "; "
#   Example: PHPSESSID=abc123xyz; _ga=GA1.2.xxx; laravel_session=yyy
# ⚠️  This expires when you log out or after inactivity — refresh it regularly.
ESERVE_COOKIE=YOUR_SESSION_COOKIE_HERE

# Telegram Bot API token.
# How to get it:
#   1. Open Telegram and message @BotFather → /newbot
#   2. Follow the prompts and copy the token it gives you.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram Chat ID where notifications will be sent.
# How to get it:
#   1. Start a conversation with your new bot.
#   2. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. Look for "chat": { "id": 123456789 } in the response.
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ============================================================
# Optional Tuning (safe to leave as defaults)
# ============================================================

# How often to poll the portal, in milliseconds (default: 10 minutes)
POLL_INTERVAL_MS=600000

# Target region
TARGET_REGION=NCR

# Target service type
TARGET_SERVICE=Career Service - Professional
